{
  "name": "@xergon/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Xergon Network -- decentralized AI inference relay on Ergo",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "xergon": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./server": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "types:generate": "cd ../xergon-relay && bash scripts/codegen.sh typescript"
  },
  "keywords": [
    "xergon",
    "ergo",
    "ai",
    "inference",
    "gpu",
    "decentralized"
  ],
  "license": "MIT",
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/yargs": "^17.0.35",
    "cliffy": "^2.5.1",
    "jsdom": "^29.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2",
    "yargs": "^18.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fleet-sdk/common": "^0.10.0",
    "@fleet-sdk/core": "^0.12.0",
    "@noble/curves": "^2.0.1"
  }
}